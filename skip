//skips intro btw
(function() {
    // 1. Array of common text phrases found on skip buttons
    const skipPhrases = ['skip', 'not now', 'maybe later', 'dismiss', 'close'];

    // 2. Scan all buttons and clickable elements
    const interactiveElements = document.querySelectorAll('button, a, div[role="button"], span');

    interactiveElements.forEach(el => {
        const text = el.innerText.trim().toLowerCase();
        
        // 3. If the button text matches a skip phrase, click it
        if (skipPhrases.some(phrase => text === phrase)) {
            el.click();
            console.log(`✅ Automatically skipped survey using element text: "${el.innerText}"`);
        }
    });

    // 4. Set up an observer to catch any popups that appear dynamically later
    const observer = new MutationObserver(() => {
        document.querySelectorAll('button, a, div[role="button"]').forEach(el => {
            const text = el.innerText.trim().toLowerCase();
            if (skipPhrases.some(phrase => text === phrase)) {
                el.click();
            }
        });
    });

    observer.observe(document.body, { childList: true, subtree: true });
})();
